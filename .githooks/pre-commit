#!/bin/sh
set -e

# Format only staged Swift files with Apple swift-format, then re-stage them.
# Pods are excluded so vendored sources are never rewritten.

staged_files="$(mktemp)"
trap 'rm -f "$staged_files"' EXIT

git diff --cached --name-only -z --diff-filter=d -- '*.swift' ':(exclude)Pods/' > "$staged_files"

if [ -s "$staged_files" ]; then
  xargs -0 xcrun swift-format format --in-place -- < "$staged_files"
  xargs -0 git add -- < "$staged_files"
fi
